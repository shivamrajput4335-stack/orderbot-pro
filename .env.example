# OrderBot Pro - Environment Variables Example
# Copy this to .env and fill in your values
# NEVER commit .env to git!

# Supabase Configuration
SUPABASE_URL=https://xaajavxegbcahusslypx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key-here>

# Server Configuration
PORT=3000
NODE_ENV=production

# Note: Frontend uses browser environment, not this .env
# Frontend will use hardcoded SUPABASE_URL and SUPABASE_ANON_KEY from index.html
